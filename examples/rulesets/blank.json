{
  "$schema": "../../ruleset.schema.json",
  "name": "Blank Ruleset",
  "version": "0.1",
  "description": "Ignores comments",
  "rules": {
    "#": "allowed",
    "# adc": "allowed",
    "# adjrange": "allowed",
    "# aux": "allowed",
    "# beacon": "allowed",
    "# beeper": "allowed",
    "# betaflight": {
      "rule": "contains_any",
      "contains_any": [
        "aafe4102e"
      ],
      "note": "Looks for the GIT hashes, usually the first 9 letters. Loaded with all version from 4.50 onwards",
      "token_length": 2,
      "required": true
    },
    "# color": "allowed",
    "# config": "allowed",
    "# config:": "allowed",
    "# diff": "allowed",
    "# dma": "allowed",
    "# dump": "allowed",
    "# end": "allowed",
    "# feature": "allowed",
    "# led": "allowed",
    "# map": "allowed",
    "# master": "allowed",
    "# mixer": "allowed",
    "# mode_color": "allowed",
    "# name:": "allowed",
    "# pin": "allowed",
    "# profile": "allowed",
    "# rateprofile": "allowed",
    "# reset": "allowed",
    "# resources": "allowed",
    "# restore": "allowed",
    "# rxfail": "allowed",
    "# rxrange": "allowed",
    "# save": "allowed",
    "# serial": "allowed",
    "# servo": "allowed",
    "# start": "allowed",
    "# timer": "allowed",
    "# timup": "allowed",
    "# version": "allowed",
    "# vtx": "allowed",
    "# vtxtable": "allowed",
    "batch end": "allowed",
    "batch start": "allowed",
    "dump -all": "allowed"
  }
}