{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Config Whisperer Ruleset",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of this ruleset."
    },
    "description": {
      "type": "string",
      "description": "A short description of what this ruleset validates."
    },
    "rules": {
      "type": "object",
      "description": "A map of parameter keys to their validation rules.",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string",
            "enum": ["allowed"],
            "description": "Simple rule allowing any value for this parameter."
          },
          {
            "type": "object",
            "properties": {
              "rule": {
                "type": "string",
                "enum": [
                  "allowed",
                  "equals",
                  "not_equals",
                  "range",
                  "forbidden",
                  "one_of",
                  "includes_all",
                  "token_set",
                  "review",
                  "positional"
                ],
                "description": "The type of validation to perform."
              },
              "value": {
                "type": "string",
                "description": "The exact value required or forbidden (for 'equals' and 'not_equals')."
              },
              "min": {
                "type": "number",
                "description": "Minimum allowed numeric value (for 'range')."
              },
              "max": {
                "type": "number",
                "description": "Maximum allowed numeric value (for 'range')."
              },
              "values": {
                "type": "array",
                "items": { "type": "string" },
                "description": "List of values for 'one_of' (any must match) or 'includes_all' (all must be present)."
              },
              "tokens": {
                "type": "array",
                "items": { "type": "string" },
                "description": "The exact set of tokens the remainder must contain (for 'token_set')."
              },
              "pos": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "index": { "type": "integer" },
                    "allowed": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  },
                  "required": ["index", "allowed"]
                },
                "description": "Positional constraints for tokenized values."
              },
              "note": {
                "type": "string",
                "description": "An optional note to display as a tooltip for this rule."
              },
              "token_length": {
                "type": "integer",
                "minimum": 1,
                "maximum": 4,
                "description": "The number of tokens that make up the parameter key."
              },
              "required": {
                "type": "boolean",
                "description": "If true, the parameter must exist in the configuration."
              }
            },
            "required": ["rule"]
          }
        ]
      }
    }
  },
  "required": ["rules"]
}
